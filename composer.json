    "description": "Zego Server Assistant",
    "keywords": [
        "zego",
        "Server Assistant"
    ],
    "homepage": "https://www.zego.im",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "hyperf/guzzle": "^3.1",
        "hyperf/config": "~3.1.0"
    },
