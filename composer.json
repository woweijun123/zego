        "hyperf/devtool": "~3.1.0",
        "hyperf/testing": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "ZEGO\\": "src/ZEGO",
            "Test\\": "test/"
        }
    },
    "extra": {
